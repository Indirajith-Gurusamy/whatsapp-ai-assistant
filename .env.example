# Active backend profile — copy to .env in repo root
APP_ENV=local

# Backend secrets live in:
#   apps/env/local.env       (development)
#   apps/env/production.env  (production / Render)
#
# Frontend secrets live in:
#   apps/frontend/.env.development.local  (npm run dev)
#   apps/frontend/.env.production.local   (npm run build)
#
# See apps/env/*.env.example and apps/frontend/.env.*.example for templates.
#
# Optional Gmail IMAP (seed for Settings → Email tab):
# GMAIL_EMAIL=
# GMAIL_APP_PASSWORD=
# GMAIL_IMAP_HOST=imap.gmail.com
# GMAIL_IMAP_PORT=993
# GMAIL_POLL_INTERVAL_SECONDS=60
